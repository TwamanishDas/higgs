<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
  xsi:type="TaskPaneApp">

  <!-- ── Required header fields (order is enforced by schema) ── -->
  <Id>a7f3c2d1-4e85-4b9a-bc12-9d8e5f6a0123</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Higgs</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Higgs"/>
  <Description DefaultValue="Send your Excel selection to Higgs and get AI analysis on your desktop widget"/>

  <!-- IconUrl and SupportUrl are REQUIRED by the schema -->
  <IconUrl DefaultValue="http://localhost:5050/addin/icon32.png"/>
  <HighResolutionIconUrl DefaultValue="http://localhost:5050/addin/icon80.png"/>
  <SupportUrl DefaultValue="https://github.com/TwamanishDas/higgs"/>

  <!-- AppDomains must appear BEFORE Hosts -->
  <AppDomains>
    <AppDomain>http://localhost:5050</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Workbook"/>
  </Hosts>

  <DefaultSettings>
    <SourceLocation DefaultValue="http://localhost:5050/addin/taskpane.html"/>
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>

  <!-- ── Version overrides: ribbon buttons + function file ── -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
                    xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Workbook">
        <DesktopFormFactor>

          <!-- Function file hosts the JS that runs when buttons are clicked -->
          <FunctionFile resid="Commands.Url"/>

          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="HiggsGroup">
                <Label resid="GroupLabel"/>

                <!-- Button 1: Send selected range to Higgs -->
                <Control xsi:type="Button" id="SendSelectionBtn">
                  <Label resid="SendBtnLabel"/>
                  <Supertip>
                    <Title resid="SendBtnTitle"/>
                    <Description resid="SendBtnDesc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon16"/>
                    <bt:Image size="32" resid="Icon32"/>
                    <bt:Image size="80" resid="Icon80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>sendSelectionToAria</FunctionName>
                  </Action>
                </Control>

                <!-- Button 2: Send full sheet summary to Higgs -->
                <Control xsi:type="Button" id="SendSheetBtn">
                  <Label resid="SheetBtnLabel"/>
                  <Supertip>
                    <Title resid="SheetBtnTitle"/>
                    <Description resid="SheetBtnDesc"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon16"/>
                    <bt:Image size="32" resid="Icon32"/>
                    <bt:Image size="80" resid="Icon80"/>
                  </Icon>
                  <Action xsi:type="ExecuteFunction">
                    <FunctionName>sendSheetSummaryToAria</FunctionName>
                  </Action>
                </Control>

              </Group>
            </OfficeTab>
          </ExtensionPoint>

        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="http://localhost:5050/addin/commands.html"/>
        <bt:Url id="Taskpane.Url" DefaultValue="http://localhost:5050/addin/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel"    DefaultValue="Higgs AI"/>
        <bt:String id="SendBtnLabel"  DefaultValue="Ask Higgs"/>
        <bt:String id="SendBtnTitle"  DefaultValue="Send Selection to Higgs"/>
        <bt:String id="SheetBtnLabel" DefaultValue="Sheet Summary"/>
        <bt:String id="SheetBtnTitle" DefaultValue="Send Sheet to Higgs"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="SendBtnDesc"  DefaultValue="Sends your selected cells to the Higgs desktop widget for AI analysis. No task pane — everything happens on your desktop."/>
        <bt:String id="SheetBtnDesc" DefaultValue="Sends the active sheet headers and a data sample to Higgs for analysis and insights."/>
      </bt:LongStrings>
      <bt:Images>
        <bt:Image id="Icon16" DefaultValue="http://localhost:5050/addin/icon16.png"/>
        <bt:Image id="Icon32" DefaultValue="http://localhost:5050/addin/icon32.png"/>
        <bt:Image id="Icon80" DefaultValue="http://localhost:5050/addin/icon80.png"/>
      </bt:Images>
    </Resources>

  </VersionOverrides>
</OfficeApp>
